{
  "name": "handwritten",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "private": true,
  "description": "Hot-reload practice environment for handwritten coding interview problems",
  "scripts": {
    "start": "tsx runner/index.js",
    "start:debug": "tsx runner/index.debug.js",
    "test": "jest",
    "media": "bash scripts/generate-media.sh",
    "media:dry-run": "bash scripts/generate-media.sh --dry-run"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/problems/"
    ],
    "transform": {
      "\\.[jt]sx?$": "babel-jest"
    }
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "targets": {
            "node": "current"
          }
        }
      ],
      [
        "@babel/preset-react",
        {
          "runtime": "automatic"
        }
      ]
    ]
  },
  "dependencies": {
    "@datastructures-js/queue": "^4.3.0",
    "@inkjs/ui": "^2.0.0",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.0",
    "ink": "^6.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "babel-jest": "^29.7.0",
    "ink-testing-library": "^4.0.0",
    "jest": "^29.7.0",
    "tsx": "^4.0.0"
  },
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=18 <=22"
  }
}
