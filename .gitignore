.DS_Store
node_modules/
__pycache__/

# User configuration
config.json
.vscode-data/
.pnp.*
workspace/*
!workspace/.gitkeep
!workspace/package.json

# Agent-generated problems (keep pre-packaged ones, ignore new generations)
problems/*
!problems/sample-problem/
!problems/flatten-and-sum/
!problems/best-available-seat/
!problems/meeting-room-finder/
!problems/short-code-registry/

# Agent skill draft payloads
.agents/.draft/*.json

# Generated by init-skills.js (source of truth is .claude/skills/)
.agents/skills/

# Debug mode output
.debug/
!.debug/.gitkeep

# media/output/ is intentionally committed — GIFs are served by GitHub README rendering
# To regenerate: run scripts/generate-media.sh (requires vhs)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
